{
  "expo": {
    "name": "LatchLog",
    "slug": "LatchLog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "latchlog",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.matannavon.latchlog",
      "deploymentTarget": "16.0",
      "associatedDomains": [
        "applinks:latchlogs.com",
        "appclips:latchlogs.com"
      ],
      "entitlements": {
        "com.apple.developer.associated-appclip-app-identifiers": [
          "$(AppIdentifierPrefix)com.matannavon.latchlog.Clip"
        ]
      },
      "infoPlist": {
        "NFCReaderUsageDescription": "LatchLog uses NFC to identify door locks",
        "NSLocationWhenInUseUsageDescription": "LatchLog uses your location to set lock positions and remind you to lock",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "LatchLog monitors your location in the background to send lock reminders when you leave",
        "NSLocationAlwaysUsageDescription": "LatchLog monitors your location in the background to send lock reminders when you leave",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.latchlog.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.NFC",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      [
        "react-native-nfc-manager",
        {
          "includeNdefEntitlement": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "LatchLog needs camera access to scan QR codes on locks"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "LatchLog monitors your location in the background to send lock reminders when you leave",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "115c5d2d-f926-4e04-a3ee-46731568754e"
      }
    },
    "owner": "matannavon"
  }
}
